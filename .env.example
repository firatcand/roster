# Copy this file to .env and fill in real values. .env is gitignored.

# Anthropic — usually managed by Claude Code itself
# ANTHROPIC_API_KEY=

# Communication
SLACK_BOT_TOKEN=

# HITL routing — per function. Each function's agents post HITL to its channel.
# When you add a new function via create-function, add a corresponding entry here.
SLACK_HITL_CHANNEL_GTM=#gtm
SLACK_HITL_CHANNEL_PRODUCT=#product
SLACK_HITL_CHANNEL_DESIGN=#design
SLACK_HITL_CHANNEL_OPS=#ops

# Cross-cutting infrastructure agents (dreamer, chief-of-staff) share the admin channel.
SLACK_HITL_CHANNEL_ADMIN=#admin

# Tool credentials — uncomment and fill in only the ones your agents actually use.
# CRM / outreach
# HEYREACH_API_KEY=
# APOLLO_API_KEY=
# ATTIO_API_KEY=

# Email / calendar (Gmail MCP and Google Calendar MCP usually handle auth themselves)
# GMAIL_OAUTH_REFRESH=
# GOOGLE_CALENDAR_OAUTH_REFRESH=

# Twitter / X
# X_API_KEY=
# X_API_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_SECRET=

# LinkedIn
# LINKEDIN_SESSION_COOKIE=

# Notion
# NOTION_TOKEN=

# Repo path (set by scripts, not usually edited manually)
AGENT_TEAM_ROOT=
