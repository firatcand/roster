# agent-team crontab
# Reinstall after edits: bash scripts/cron/install.sh
#
# Format: m h dom mon dow command
# Each entry calls a wrapper in scripts/cron/wrappers/.
# Wrappers handle env loading, working dir, logging.
#
# Reference times (your local timezone):
#   Nightly dreamer: 03:00
#   Daily outreach:  09:30 weekdays
#   Twitter sweep:   every 30 min during waking hours
#
# Example (commented — uncomment when adding real jobs):

# Dreamer — nightly reinforcement pass
# 0 3 * * * ~/agent-team/scripts/cron/wrappers/dreamer-nightly.sh

# Acme Corp outreach — weekday mornings
# 30 9 * * 1-5 ~/agent-team/scripts/cron/wrappers/_demo-outreach-daily.sh
