# Secrets and credentials
.env
.env.local
*.pem
*.key

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
*~

# Cron logs (committed example: keep .gitkeep, ignore actual logs)
logs/cron/*.log
.dogfood/logs/cron/*.log

# Large binary brand assets (use external storage)
.dogfood/projects/*/brand/assets/
*.mp4
*.mov
*.psd
*.ai
*.fig

# Temp / scratch
**/scratch/
**/tmp/
**/.cache/

# Python / Node if you add scripts
__pycache__/
*.pyc
node_modules/

# Local Claude Code permission overrides (root + any nested .claude/, e.g. .dogfood/.claude/)
**/.claude/settings.local.json

# Dogfood runtime state — preserve directories with .gitkeep, ignore actual logs
.dogfood/chief-of-staff/logs/2*/
.dogfood/dreamer/logs/2*/
.dogfood/**/log/runs/2*/
.dogfood/**/log/feedback/2*/

# Dreamer pending candidates (regenerated each run)
.dogfood/dreamer/pending/*
!.dogfood/dreamer/pending/.gitkeep

# Forge planning artifacts — internal framework design, not shipped.
# Anchored to repo root so nested `plans/`/`spec/` (e.g. inside templates/scaffold/) are not ignored.
/spec/
/plans/

# Build artifacts — produced by tsdown; included in npm pack via files allowlist
/bin/
/dist/

# Personal learning store — local-only. The framework supports the workflow
# (users get their own docs/learnings/ when they scaffold), but our entries
# are CLI-development specific and don't ship with the open-source repo.
docs/learnings/

