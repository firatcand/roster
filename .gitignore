# Secrets and credentials
.env
.env.local
*.pem
*.key
.infisical.json

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
*~

# Cron logs (committed example: keep .gitkeep, ignore actual logs)
logs/cron/*.log

# Large binary brand assets (use external storage)
roster-banner*.png
*.mp4
*.mov
*.psd
*.ai
*.fig

# Temp / scratch
**/scratch/
**/tmp/
**/.cache/

# Python / Node if you add scripts
__pycache__/
*.pyc
node_modules/

# Local Claude Code permission overrides (root + any nested .claude/)
**/.claude/settings.local.json
**/.claude/scheduled_tasks.lock

# Forge planning artifacts — internal framework design, not shipped.
# Anchored to repo root so nested `plans/`/`spec/` (e.g. inside templates/scaffold/) are not ignored.
/spec/
/plans/

# Forge harness state (worktrees, logs, regenerated CONTEXT.md/.version) is
# ignored by the forge-managed block at the end of this file, which re-includes
# the one tracked config file (.forge/settings.yaml). That block's `/.forge/*` is
# anchored so a nested `templates/scaffold/.forge/` (if ever shipped) is not ignored.

# Claude Code native worktrees (created by EnterWorktree). Anchored so a
# nested `templates/scaffold/.claude/worktrees/` would not be ignored.
/.claude/worktrees/

# Build artifacts — produced by tsdown; included in npm pack via files allowlist
/bin/
/dist/

# Personal learning store — local-only. The framework supports the workflow
# (users get their own docs/learnings/ when they scaffold), but our entries
# are CLI-development specific and don't ship with the open-source repo.
docs/learnings/

# >>> forge-managed (do not edit between markers) >>>
/.forge/*
!/.forge/settings.yaml
/.forge.eject-backup-*/
/.claude/skills/
/.claude/agents/
/.codex/skills/
/.codex/agents/
/.gemini/skills/
/.gemini/agents/
/.agents/skills/
/.cursor/agents/
/.cursor/rules/forge-context.mdc
# <<< forge-managed <<<
