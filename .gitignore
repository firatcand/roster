# Secrets and credentials
.env
.env.local
*.pem
*.key

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
*~

# Cron logs (committed example: keep .gitkeep, ignore actual logs)
logs/cron/*.log

# Large binary brand assets (use external storage)
roster-banner*.png
*.mp4
*.mov
*.psd
*.ai
*.fig

# Temp / scratch
**/scratch/
**/tmp/
**/.cache/

# Python / Node if you add scripts
__pycache__/
*.pyc
node_modules/

# Local Claude Code permission overrides (root + any nested .claude/)
**/.claude/settings.local.json
**/.claude/scheduled_tasks.lock

# Forge planning artifacts — internal framework design, not shipped.
# Anchored to repo root so nested `plans/`/`spec/` (e.g. inside templates/scaffold/) are not ignored.
/spec/
/plans/

# Forge harness state — worktrees and per-worktree task binding markers
# (created by skills/pickup-task). Anchored to repo root so a nested
# `templates/scaffold/.forge/` (if ever shipped) is not ignored.
# Pattern uses `/*` (not `/`) so we can re-include `.forge/CLAUDE.md`
# (the Forge methodology doc) below — gitignore can't re-include children
# of a fully-ignored directory.
/.forge/*
!/.forge/CLAUDE.md

# Claude Code native worktrees (created by EnterWorktree). Anchored so a
# nested `templates/scaffold/.claude/worktrees/` would not be ignored.
/.claude/worktrees/

# Build artifacts — produced by tsdown; included in npm pack via files allowlist
/bin/
/dist/

# Personal learning store — local-only. The framework supports the workflow
# (users get their own docs/learnings/ when they scaffold), but our entries
# are CLI-development specific and don't ship with the open-source repo.
docs/learnings/
