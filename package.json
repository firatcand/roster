{
  "name": "@firatcand/roster",
  "version": "1.2.0",
  "description": "A CLI that scaffolds a structured multi-agent workspace on top of AI coding tools (Claude Code, Codex CLI, Gemini)",
  "type": "module",
  "bin": {
    "roster": "bin/roster.js"
  },
  "files": [
    "bin/",
    "lib/",
    "skills/",
    "agents/",
    "templates/",
    "data/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": "^22.18.0 || >=24.0.0"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "dev": "tsdown --watch",
    "test": "node --test --experimental-strip-types 'test/**/*.test.ts'",
    "test:update-golden": "node --experimental-strip-types scripts/update-golden.ts",
    "test:update-golden:stub": "node --experimental-strip-types scripts/update-golden-stub.ts",
    "smoke": "bash test/smoke.sh",
    "e2e:schedule": "bash test/e2e-schedule.sh",
    "perf": "bash test/perf.sh",
    "test:scaffold-scripts": "bash test/new-agent-slash-only.sh",
    "probe:claude-url": "bash scripts/probe-claude-url-scheme.sh"
  },
  "keywords": [
    "claude-code",
    "claude",
    "codex",
    "gemini",
    "ai-agent",
    "agentic",
    "skills",
    "subagents",
    "agent-team",
    "operations",
    "gtm",
    "linear",
    "slack"
  ],
  "author": "Firat Can Basarir",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/firatcand/roster.git"
  },
  "homepage": "https://github.com/firatcand/roster#readme",
  "bugs": {
    "url": "https://github.com/firatcand/roster/issues"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.3",
    "chalk": "^5.3.0",
    "fs-extra": "^11.2.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.17.2",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3"
  }
}
