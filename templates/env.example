# roster workspace environment
#
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# Each agent's docs name the variables it expects; uncomment what you use.
#
# Using 1Password or Infisical? Render secrets into this file instead of
# hand-filling — `op inject` / `infisical export`. Recipes:
# https://github.com/firatcand/roster/blob/main/docs/SECRETS.md
# (Do NOT wrap roster with `op run` / `infisical run` — it can leak a
#  model-provider key into Codex and trigger API billing.)

# --- Linear (MCP-driven workflows) ---
# LINEAR_API_KEY=lin_api_xxx
# LINEAR_TEAM_ID=xxx
# LINEAR_PROJECT_ID=xxx

# --- Slack HITL routing ---
# SLACK_BOT_TOKEN=xoxb-xxx
# SLACK_HITL_CHANNEL_GTM=gtm-hitl
# SLACK_HITL_CHANNEL_PRODUCT=product-hitl
# SLACK_HITL_CHANNEL_DESIGN=design-hitl
# SLACK_HITL_CHANNEL_OPS=ops-hitl
# SLACK_HITL_CHANNEL_ADMIN=admin-hitl

# --- LLM providers (for cron-driven workflows that run outside Claude Code) ---
# OPENAI_API_KEY=sk-xxx
# ANTHROPIC_API_KEY=sk-ant-xxx

# --- Brain (shared team memory — Postgres/Neon; see docs/HOWTO.md §11) ---
# Connection strings to your brain. The runtime role is restricted (append-only);
# the admin URL is used for init/doctor/gc/config/export. OPENAI_API_KEY above
# powers embeddings (semantic `brain query`) when enabled.
# ROSTER_BRAIN_URL=postgresql://roster_brain_rw:...@host/db
# ROSTER_BRAIN_ADMIN_URL=postgresql://<owner>:...@host/db

# --- Ops backend (`roster ops setup`, workspace operations ledger) ---
# Connection strings for the postgres-s3 ops backend. Only needed with
# `--database dedicated` — brain reuse (`--database brain`) needs nothing new,
# it uses ROSTER_BRAIN_URL/ROSTER_BRAIN_ADMIN_URL above. The runtime role is
# restricted (append-only); the admin URL is used by setup only.
# ROSTER_OPS_URL=postgresql://<runtime-role>:...@host/db
# ROSTER_OPS_ADMIN_URL=postgresql://<owner>:...@host/db

# --- Brain file store (`roster brain fs`, S3-backed — v1.8.0+) ---
# Bucket/region/endpoint live IN the brain (roster brain config set files.bucket ...);
# only the credentials are env-only. Works with AWS S3, Cloudflare R2, Backblaze B2, MinIO.
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=eu-central-1
# AWS_SESSION_TOKEN=...        # only for temporary/STS credentials

# --- Optional integrations ---
# NOTION_API_KEY=secret_xxx
# GITHUB_TOKEN=ghp_xxx
